---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Aprende desarrollo web de forma interactiva" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
    <!-- Theme initializer: reads localStorage or OS preference and sets data-theme on <html> -->
    <script>
    (function(){
      try{
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      }catch(e){/* ignore */}
    })();
    </script>
	</body>
</html>
<style is:global>
	:root {
		--accent: 26, 188, 156;
		--accent-light: 129, 140, 248;
		--accent-dark: 8, 15, 32;
		--accent-gradient: linear-gradient(135deg, #22d3ee 0%, #6366f1 45%, #ec4899 100%);
    --bg-dark: #060816;
    --bg-panel: rgba(255, 255, 255, 0.06);
    --bg-panel-strong: rgba(255, 255, 255, 0.09);
    --card-bg: rgba(255, 255, 255, 0.06);
    --border-soft: rgba(255, 255, 255, 0.12);
    --primary: #22d3ee;
    --secondary: #6366f1;
    --tertiary: #ec4899;
    --text-main: #f8fafc;
    --text-muted: #94a3b8;
    --success: #34d399;
    --warning: #fbbf24;
	}

  /* Light theme overrides */
  html[data-theme="light"] {
    --bg-dark: #f7fafc;
    --bg-panel: rgba(10, 11, 20, 0.02);
    --bg-panel-strong: rgba(10, 11, 20, 0.04);
    --card-bg: #ffffff;
    --border-soft: rgba(2,6,23,0.06);
    --primary: #0ea5e9;
    --secondary: #6366f1;
    --tertiary: #ec4899;
    --text-main: #0b1220;
    --text-muted: #475569;
  }

  /* Dark theme explicit values (explicit for clarity) */
  html[data-theme="dark"] {
    /* defaults already tuned for dark in :root */
  }
	html {
		font-family: 'Outfit', system-ui, sans-serif;
		background: var(--bg-dark);
    color: var(--text-main);
    scroll-behavior: smooth;
    overflow-x: hidden;
    height: 100%;
	}
	body {
		margin: 0;
		padding: 0;
    min-height: 100%;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
	}
	code {
		font-family:
			Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
	}
  /* Global premium button styles */
  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--accent-gradient);
    color: white;
    box-shadow: 0 10px 30px rgba(34, 211, 238, 0.2);
    border: 1px solid rgba(255,255,255,0.12);
  }
  .btn-primary:hover {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 18px 38px rgba(34, 211, 238, 0.24);
  }
  .btn-secondary {
    background: var(--bg-panel);
    color: white;
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-soft);
  }
  .btn-secondary:hover {
    background: var(--bg-panel-strong);
  }
</style>
