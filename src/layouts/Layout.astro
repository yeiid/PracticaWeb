---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Aprende desarrollo web de forma interactiva" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
    <!-- Theme initializer: reads localStorage or OS preference and sets data-theme on <html> -->
    <script>
    (function(){
      try{
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      }catch(e){/* ignore */}
    })();
    </script>
	</body>
</html>
<style is:global>
	:root {
		--accent: 249, 115, 22;
		--accent-light: 56, 189, 248;
		--accent-dark: 11, 15, 26;
		--accent-gradient: linear-gradient(135deg, #F97316 0%, #38BDF8 100%);
    --bg-dark: #0B0F1A;
    --bg-panel: rgba(26, 34, 53, 0.6);
    --bg-panel-strong: rgba(26, 34, 53, 0.9);
    --card-bg: rgba(26, 34, 53, 0.8);
    --border-soft: rgba(37, 46, 66, 0.8);
    --primary: #F97316;
    --secondary: #38BDF8;
    --tertiary: #8B5CF6;
    --text-main: #F8FAFC;
    --text-muted: #4A5568;
    --success: #34D399;
    --warning: #FBBF24;
    --nj-orange: #F97316;
    --nj-blue: #38BDF8;
    --nj-surface: #1A2235;
    --nj-border: #252E42;
    --nj-code-bg: #0D1320;
    --font-heading: 'Space Grotesk', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', Menlo, monospace;
	}

  /* Light theme overrides */
  html[data-theme="light"] {
    --bg-dark: #F8FAFC;
    --bg-panel: rgba(255, 255, 255, 0.8);
    --bg-panel-strong: rgba(255, 255, 255, 0.95);
    --card-bg: #FFFFFF;
    --border-soft: rgba(37, 46, 66, 0.15);
    --primary: #F97316;
    --secondary: #38BDF8;
    --tertiary: #8B5CF6;
    --text-main: #0B0F1A;
    --text-muted: #4A5568;
    --nj-surface: #FFFFFF;
    --nj-border: rgba(37, 46, 66, 0.15);
    --nj-code-bg: #F1F5F9;
  }

  /* Dark theme explicit values (explicit for clarity) */
  html[data-theme="dark"] {
    /* defaults already tuned for dark in :root */
  }
	html {
		font-family: var(--font-heading), system-ui, sans-serif;
		background: var(--bg-dark);
    color: var(--text-main);
    scroll-behavior: smooth;
    overflow-x: hidden;
    height: 100%;
	}
	body {
		margin: 0;
		padding: 0;
    min-height: 100%;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
	}
	code {
		font-family: var(--font-mono);
	}
  /* Global premium button styles */
  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    font-family: var(--font-heading);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--accent-gradient);
    color: white;
    box-shadow: 0 10px 30px rgba(249, 115, 22, 0.25);
    border: 1px solid rgba(249, 115, 22, 0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 18px 38px rgba(249, 115, 22, 0.3);
  }
  .btn-secondary {
    background: var(--bg-panel);
    color: var(--text-main);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-soft);
  }
  .btn-secondary:hover {
    background: var(--bg-panel-strong);
    border-color: var(--nj-orange);
  }
</style>
