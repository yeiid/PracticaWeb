FROM node:22-alpine

WORKDIR /app

# Instalar pnpm y herramientas básicas
RUN npm install -g pnpm && apk add --no-cache netcat-openbsd bash

# Instalar dependencias primero para aprovechar la caché
COPY package.json pnpm-lock.yaml* ./
RUN npm install --legacy-peer-deps

# Copiar el resto del código
COPY . .

# Exponer el puerto de Astro
EXPOSE 4321

# Configuración de red para Astro dev
ENV HOST=0.0.0.0
ENV PORT=4321

# Ejecutar en modo desarrollo
CMD ["npm", "run", "dev", "--", "--host"]
