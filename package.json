{
  "name": "academia-web",
  "version": "1.0.0",
  "description": "Plataforma completa de aprendizaje web",
  "scripts": {
    "start:main": "node serve.js",
    "start:html": "cd HTML && node serve.js",
    "start:css": "cd CSS && node serve.js",
    "start:js": "cd JS && node serve.js",
    "start:api": "cd api && node -r dotenv/config server.js",
    "start:frontend": "cd frontend && pnpm install && pnpm start",
    "dev": "concurrently \"pnpm run start:api\" \"pnpm run start:frontend\"",
    "install:all": "pnpm install && cd api && pnpm install && cd ../frontend && pnpm install"
  },
  "keywords": ["html", "css", "javascript", "react", "backend", "educacion"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
